# BalkanMarket API — Environment Variables
# Kopiraj u .env i popuni vrijednosti

# ── Baza ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/balkanmarket"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=super_tajni_kljuc_promjeni_u_produkciji_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_SECRET=drugi_tajni_kljuc_za_refresh_tokene
REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend.com) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@balkanmarket.ba

# ── Crypto (Alchemy) ─────────────────────────────────────────────────────────
ALCHEMY_API_KEY=...
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
HOT_WALLET_PRIVATE_KEY=0x...
USDC_CONTRACT_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
